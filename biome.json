{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!node_modules", "!dist", "!.sisyphus", "!.husky"],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    },
    "jsxRuntime": "transparent"
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended"
    },
    "rules": {
      "recommended": true,

      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "error",
        "useJsxKeyInIterable": "error"
      },

      "suspicious": {
        "noExplicitAny": "error",
        "noExtraNonNullAssertion": "warn",
        "noArrayIndexKey": "warn",
        "noDoubleEquals": "error",
        "noDebugger": "error",
        "noConsole": "warn"
      },

      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "useConst": "error",
        "noDefaultExport": "error",
        "noNonNullAssertion": "warn",
        "noInferrableTypes": "error",
        "useAsConstAssertion": "error",
        "useNodejsImportProtocol": "error"
      },

      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 15 }
        }
      },

      "security": {
        "noDangerouslySetInnerHtml": "error",
        "noGlobalEval": "error"
      },

      "nursery": {
        "noUselessTypeConversion": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/**/*.css"],
      "linter": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      }
    },
    {
      "includes": ["tsconfig.json", "tsconfig.app.json", "tsconfig.node.json"],
      "formatter": {
        "enabled": false
      }
    },
    {
      "includes": [
        "vite.config.ts",
        "vitest.config.ts",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "noDefaultExport": "off"
          }
        }
      },
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    }
  ]
}
